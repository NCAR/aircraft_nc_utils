# -*- python -*-

tools  = ['default', 'prefixoptions', 'vardb','raf','netcdf']
env = Environment(tools=tools)
env.Append(CCFLAGS='-g -Werror -Wall -DVARDB -DZEROBIN')

env['PUBLISH_PREFIX'] = '/net/www/docs/raf/Software'

sources = Split("""
asc2cdf.cpp
plain.cpp
nasaAmes.cpp
nasaLangley.cpp
ICARTT.cpp
BADC_CSV.cpp
getmem.cpp
error.cpp
""")

asc2cdf = env.Program(target = 'asc2cdf', source = sources)
env.Default(asc2cdf)

env.Install ("$INSTALL_PREFIX/bin", 'asc2cdf')

if "publish" in COMMAND_LINE_TARGETS:
   pub = env.Install('$PUBLISH_PREFIX', ["doc/asc2cdf.html"])
   env.Alias('publish', pub)
