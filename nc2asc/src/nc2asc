#!/usr/bin/env python3

"""
NetCDF to ASCII Converter with Multi-dimensional Support

Converts NetCDF files to various ASCII formats:
- Plain ASCII (CSV or space-delimited)
- ICARTT FFI 1001 (1D time-series data)
- ICARTT FFI 2110 (multi-dimensional data)
- NASA Ames 1001

Uses YAML/JSON configuration files for customizable headers and metadata.

Copyright University Corporation for Atmospheric Research (2021-2025)
"""

import argparse
import os
import sys
from pathlib import Path
from typing import Optional

_script_dir = os.path.dirname(os.path.abspath(__file__))
_installed_lib = os.path.join(_script_dir, '..', 'lib', 'nc2asc')
_source_lib = os.path.join(_script_dir, 'lib')
if os.path.isdir(_installed_lib):
    sys.path.insert(0, _installed_lib)
elif os.path.isdir(_source_lib):
    sys.path.insert(0, _source_lib)

from config_manager import ConfigManager, parse_batch_file
from converter import NetCDFConverter
from formatters import FormatterFactory, OutputFormat as FmtOutputFormat


def parse_arguments():
    """Parse command-line arguments."""
    parser = argparse.ArgumentParser(
        description=(
            "Convert RAF/NCAR NetCDF files to ASCII formats (Plain, ICARTT, AMES).\n"
            "Run with no arguments to launch the graphical interface."
        ),
        formatter_class=argparse.RawDescriptionHelpFormatter,
        epilog="""
INPUT FILE:
  The input must be a NetCDF file following RAF/NCAR conventions. Required:
    - A 'Time' variable (seconds since midnight on the flight date)
    - Global attributes: FlightDate (MM/DD/YYYY), Platform (tail number)
  Variables can be 1D (Time,), 2D (Time x bins), or 3D (Time x sps x bins).
  Variable attributes used: units, long_name, CellSizes.

OUTPUT FILE:
  If -o is not specified, the output filename is constructed from NetCDF
  metadata: <PROJECT>-CORE_<PLATFORM>_<YYYYMMDD>_<VERSION>.<ext>
  File extension is set by format: .ict (icartt/icartt2110), .na (ames), .txt (plain).

OUTPUT FORMATS:
  plain       Plain ASCII, comma- or space-delimited, no header
  icartt      ICARTT FFI 1001 — standard 1D time-series format
  icartt2110  ICARTT FFI 2110 — multi-dimensional/histogram data
  ames        NASA Ames 1001 format

HIGH-RATE STRATEGY (for 3D variables with a samples-per-second dimension):
  first       Keep only the first sample from each second (default)
  average     Average all samples within each second
  expand      Write one row per sample, expanding the time axis

BATCH FILE FORMAT (.bat):
  if=<path>          Input NetCDF file
  of=<path>          Output file
  hd=ICARTT          Header/format: Plain, ICARTT, ICARTT2110, AMES
  dt=NoDate          Date format: yyyy-mm-dd, yyyy mm dd, NoDate
  tm=SecOfDay        Time format: hh:mm:ss, hh mm ss, SecOfDay
  sp=comma           Delimiter: comma, space
  fv=-99999          Fill value for missing data
  version=RA         Data version string
  avg=10             Averaging window in seconds (optional)
  ti=50000,70000     Time interval as start,end in seconds since midnight (optional)
  Vars=ATMP          Variable to include — repeat this line for each variable
  REM <text>         Comment line (ignored)

  Command-line arguments take precedence over batch file settings.

CONFIG FILE (YAML or JSON, passed with -c):
  Overrides default ICARTT header metadata. Example YAML structure:
    header:
      pi_name: "Last, First"
      pi_organization: "My Org"
      missing_value: -99999.0
    normal_comments:
      pi_contact_info: "phone, address, email"
      platform: "NSF/NCAR {platform} {tail_number}"
      revision: "RA"
      revision_comments:
        RA: "Field Data"
  See config/example_config.yaml for the full list of available keys.

EXAMPLES:
  %(prog)s                                    Launch GUI (default)
  %(prog)s --gui                              Launch GUI explicitly
  %(prog)s input.nc --gui                     Launch GUI with file pre-loaded
  %(prog)s -i input.nc -o output.ict          Convert to ICARTT 1001
  %(prog)s -i input.nc -f icartt2110          Convert multidim data to ICARTT 2110
  %(prog)s -i input.nc -b batch.bat           Run with batch file settings
  %(prog)s -i input.nc -c myconfig.yaml       Use custom header config
  %(prog)s -i input.nc -v ATMP PSXC -f plain  Export two variables as plain CSV
  %(prog)s -i input.nc --start-time 60000 --end-time 75000 -f icartt
        """
    )

    parser.add_argument('input', nargs='?',
                        help='Input NetCDF file (positional, or use -i)')
    parser.add_argument('-i', '--input-file', dest='input_file_flag', metavar='INPUT',
                        help='Input NetCDF file (alternative to positional argument)')
    parser.add_argument('-b', '--batch', metavar='FILE',
                        help='Batch file (.bat) with conversion settings; CLI args take precedence')
    parser.add_argument('-o', '--output', metavar='FILE',
                        help='Output file path; if omitted, name is derived from NetCDF metadata')
    parser.add_argument('-c', '--config', metavar='FILE',
                        help='YAML or JSON config file to override default ICARTT header values')
    parser.add_argument('-f', '--format',
                        choices=['plain', 'icartt', 'icartt2110', 'ames'],
                        default=None,
                        help='Output format (default: icartt)')
    parser.add_argument('-v', '--variables', nargs='+', metavar='VAR',
                        help='Variable names to include; default is all non-Time variables')
    parser.add_argument('--delimiter', choices=['comma', 'space'],
                        default=None,
                        help='Column delimiter for plain format (default: comma)')
    parser.add_argument('--date-format',
                        choices=['yyyy-mm-dd', 'yyyy mm dd', 'NoDate'],
                        default=None,
                        help='Date column format (default: NoDate for ICARTT, yyyy-mm-dd for plain)')
    parser.add_argument('--time-format',
                        choices=['hh:mm:ss', 'hh mm ss', 'SecOfDay'],
                        default=None,
                        help='Time column format (default: SecOfDay)')
    parser.add_argument('--fill-value', type=float, default=None,
                        help='Fill value written for missing data (default: -99999)')
    parser.add_argument('--averaging', type=int, metavar='SECONDS',
                        help='Average data into N-second bins before writing')
    parser.add_argument('--version', default=None, metavar='CODE',
                        help='Data version string written to ICARTT header (e.g., RA, RB)')
    parser.add_argument('--start-time', type=float, metavar='SECONDS',
                        help='Trim output to start at this time (seconds since midnight)')
    parser.add_argument('--end-time', type=float, metavar='SECONDS',
                        help='Trim output to end at this time (seconds since midnight)')
    parser.add_argument('--high-rate-strategy',
                        choices=['first', 'average', 'expand'],
                        default=None,
                        help='How to handle 3D high-rate variables: first, average, or expand (default: first)')
    parser.add_argument('--ames-file-code', metavar='CC', default=None,
                        help='Two-letter NASA Ames filename prefix CC in CCyyyyMMdd_Rn.PLATFORM (default: RF)')
    parser.add_argument('--validate', action='store_true',
                        help='Validate the output file after writing')
    parser.add_argument('--gui', action='store_true',
                        help='Launch the graphical interface (also the default when no args are given)')

    return parser.parse_args()


def launch_gui(input_file: Optional[str] = None):
    """Launch the GUI application."""
    import signal

    try:
        from PyQt5.QtWidgets import QApplication
        from PyQt5.QtCore import Qt, QTimer
    except ImportError:
        print("Error: PyQt5 is required for GUI mode.")
        print("Install with: pip install PyQt5")
        sys.exit(1)

    try:
        from gui import NC2ASCGUI
    except ImportError:
        print("Error: Can't locate NC2ASCGUI")
        sys.exit(1)

    # Enable high DPI scaling
    QApplication.setAttribute(Qt.AA_EnableHighDpiScaling, True)
    QApplication.setAttribute(Qt.AA_UseHighDpiPixmaps, True)

    app = QApplication(sys.argv)
    app.setStyle('Fusion')
    app.setApplicationName('nc2asc')
    app.setOrganizationName('NCAR/EOL')

    # Qt's event loop blocks Python signal handling; a short timer lets Python
    # process SIGINT so Ctrl+C exits cleanly.
    signal.signal(signal.SIGINT, lambda *_: app.quit())
    interrupt_timer = QTimer()
    interrupt_timer.start(200)
    interrupt_timer.timeout.connect(lambda: None)

    window = NC2ASCGUI()
    window.show()

    # Load input file if provided
    if input_file:
        window.load_netcdf_file(input_file)

    sys.exit(app.exec_())


def main():
    """Main entry point."""
    if len(sys.argv) == 1:
        launch_gui()
        return

    args = parse_arguments()

    # Launch GUI if requested
    if args.gui:
        launch_gui(args.input)
        return

    # Load batch file settings if provided
    batch_settings = {}
    if args.batch:
        try:
            batch_settings = parse_batch_file(args.batch)
            print(f"Loaded batch file: {args.batch}")
        except FileNotFoundError:
            print(f"Error: Batch file not found: {args.batch}")
            sys.exit(1)
        except Exception as e:
            print(f"Error reading batch file: {e}")
            sys.exit(1)

    # Determine input file (-i flag, positional arg, or batch file)
    input_file = args.input_file_flag or args.input or batch_settings.get('input_file')
    if not input_file:
        print("Error: No input file specified. Use -i, positional argument, or 'if=' in batch file.")
        sys.exit(1)

    # Determine output file (command line takes precedence over batch file)
    output_file = args.output or batch_settings.get('output_file')

    # Build CLI args dict for ConfigManager
    cli_args = {
        'output_format': args.format,
        'delimiter': args.delimiter,
        'date_format': args.date_format,
        'time_format': args.time_format,
        'fill_value': args.fill_value,
        'version': args.version,
        'variables': args.variables,
        'averaging': args.averaging,
        'start_time': args.start_time,
        'end_time': args.end_time,
        'high_rate_strategy': args.high_rate_strategy,
        'ames_file_code': args.ames_file_code,
    }

    # Remove None values
    cli_args = {k: v for k, v in cli_args.items() if v is not None}

    # Create ConfigManager and load configuration
    config_path = Path(args.config) if args.config else None
    config_manager = ConfigManager(
        config_path=config_path,
        batch_settings=batch_settings,
        cli_args=cli_args
    )

    try:
        config = config_manager.load()
        print(f"Configuration loaded. Output format: {config.options.output_format.value}")
    except Exception as e:
        print(f"Error loading configuration: {e}")
        sys.exit(1)

    # Create converter with loaded config
    converter = NetCDFConverter(input_file, config)

    # Convert
    try:
        output_path = converter.convert(output_file)
        print(f"Conversion complete: {output_path}")

        # Validate if requested
        if args.validate:
            formatter = FormatterFactory.create(
                FmtOutputFormat(config.options.output_format.value),
                converter,
                config
            )
            if formatter.validate_output(Path(output_path)):
                print("Output validation: PASSED")
            else:
                print("Output validation: FAILED")
                sys.exit(1)

    except Exception as e:
        print(f"Error during conversion: {e}")
        import traceback
        traceback.print_exc()
        sys.exit(1)

#TODO: Add help statements; add usage arguments
if __name__ == "__main__":
    main()
